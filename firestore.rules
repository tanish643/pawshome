rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isBanned() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_banned == true;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can update their own profile (but not role/ban status).
      // Admins can update everything.
      allow update: if isAdmin() || (isOwner(userId) && !isBanned() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'is_banned', 'is_suspended']));
      
      // Only users can create their own profile on signup
      allow create: if isOwner(userId);
    }

    // --- Pets for Adoption ---
    match /pets_for_adoption/{petId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid && !isBanned() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
    }

    // --- Lost Pets ---
    match /lost_pets/{petId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid && !isBanned() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
    }

    // --- Found Pets ---
    match /found_pets/{petId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.finder_id == request.auth.uid && !isBanned() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.finder_id == request.auth.uid);
    }

    // --- Hosting Pets ---
    match /hosting_pets/{petId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid && !isBanned() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
    }

    // --- Adoption Interests (Submissions) ---
    match /adoption_interests/{interestId} {
      // Only admins see these requests, or the person who submitted them
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_id == request.auth.uid);
      allow create: if isAuthenticated() && !isBanned();
    }
  }
}
